includes:
    - vendor/phpstan/phpstan-phpunit/extension.neon
    - vendor/phpstan/phpstan-strict-rules/rules.neon

parameters:
    level: max
    paths:
        - src
        - tests
    tmpDir: var/phpstan
    scanFiles:
        - legacy/OrderController.php
    treatPhpDocTypesAsCertain: true
    reportUnmatchedIgnoredErrors: true
    excludePaths:
        analyse:
            - var/*
